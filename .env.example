# Canvas API
CANVAS_API_URL=https://canvas.nus.edu.sg
CANVAS_API_TOKEN=your_canvas_api_token_here

# GitHub (for auto-push to course repos)
GITHUB_OWNER=your_github_username
GITHUB_COMMIT_PREFIX=[canvas-sync]

# Data directory (where synced files are stored)
DATA_DIR=./data

# Sync schedule (24h clock, SGT timezone)
SYNC_HOUR=6
SYNC_MINUTE=0
